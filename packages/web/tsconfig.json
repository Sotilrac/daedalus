{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@daedalus/shared": ["../shared/src/index.ts"],
      "@daedalus/shared/*": ["../shared/src/*/index.ts"]
    }
  },
  "include": ["src/**/*", "../shared/src/**/*"]
}
