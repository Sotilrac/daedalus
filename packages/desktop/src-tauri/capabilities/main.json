{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Folder access, dialogs, and watch events for the active diagram folder.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "clipboard-manager:allow-write-image",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }, { "url": "http://*" }]
    },
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-write-file",
    "fs:scope-home",
    "fs:scope-document",
    "fs:scope-desktop",
    "fs:scope-download"
  ]
}
