root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Markdown legitimately uses 3-space continuation indents under numbered list
# items (Prettier formats them that way). Don't fight it.
indent_size = unset
indent_style = unset
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# LICENSE is the canonical Mozilla MPL 2.0 text; don't reformat it (the
# upstream copy carries trailing whitespace on a few continuation lines).
[LICENSE]
trim_trailing_whitespace = false
insert_final_newline = unset
