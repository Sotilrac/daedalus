user: User {
  shape: person
  style: {
    fill: "#fec601"
    stroke: "#fec601"
    font-color: "#0d3b66"
  }
}

api: API Gateway {
  style: {
    fill: "#f4f1de"
    stroke: "#f4f1de"
    stroke-width: 2
    font-color: "#0d3b66"
    bold: true
  }
}

worker: Background Worker {
  style: {
    fill: "#a3d9b1"
    stroke: "#a3d9b1"
    font-color: "#0d3b66"
  }
}

cache: Redis {
  shape: hexagon
  style: {
    fill: "#ef8b6f"
    stroke: "#ef8b6f"
    font-color: "#0d3b66"
    bold: true
  }
}

db: Postgres {
  shape: cylinder
  style: {
    fill: "#7aa6cd"
    stroke: "#7aa6cd"
    stroke-width: 2
    font-color: "#0d3b66"
    bold: true
  }
}

queue: Job Queue {
  shape: queue
  style: {
    fill: "#f4f1de"
    stroke: "#f4f1de"
    font-color: "#0d3b66"
  }
}
